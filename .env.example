# === LLM Provider ===
# Choose provider: "anthropic" (default) or "openai-codex" (ChatGPT OAuth)
KERNOS_LLM_PROVIDER=anthropic

# Anthropic (required if KERNOS_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI Codex (required if KERNOS_LLM_PROVIDER=openai-codex)
# Credentials file: .credentials/openai-codex.json
# Or set via env:
# OPENAI_CODEX_ACCESS_TOKEN=...
# OPENAI_CODEX_REFRESH_TOKEN=...
# OPENAI_CODEX_EXPIRES=...
# OPENAI_CODEX_ACCOUNT_ID=...
# OPENAI_CODEX_MODEL=gpt-5.5

# === Discord ===
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_OWNER_ID=your-discord-user-id

# === Cross-Channel Identity ===
# Ties Discord + SMS to one tenant. Format: discord:YOUR_DISCORD_USER_ID
KERNOS_INSTANCE_ID=discord:your-discord-user-id

# === Twilio SMS (optional) ===
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
OWNER_PHONE_NUMBER=+1...
# KERNOS_SMS_POLL_INTERVAL=30   # seconds; default 30

# === Google Calendar MCP ===
# OAuth credentials JSON from Google Cloud Console > APIs & Services > Credentials
GOOGLE_OAUTH_CREDENTIALS_PATH=/path/to/your/gcp-oauth.keys.json

# === Optional Services ===
# BRAVE_API_KEY=...          # Web search (Brave Search API)
# VOYAGE_API_KEY=...         # Enhanced embeddings (Voyage AI) — falls back to hash-only dedup

# === Storage ===
# KERNOS_DATA_DIR=./data     # Root directory for all persistent data

# === Process Lifecycle ===
# Both vars are read by start.sh and scripts/manage-kernos-service.sh.
# Set values here in .env and the scripts pick them up automatically;
# no shell exports needed.
#
#   KERNOS_START_KILL_PRIOR        — when 1 (default), running start.sh
#                                    terminates any prior Kernos instance
#                                    from THIS folder before booting fresh.
#                                    Set to 0 to disable (rare; mostly for
#                                    debugging). Folder-scoped — does not
#                                    touch other Kernos clones on the same
#                                    machine.
#
#   KERNOS_AUTO_RESTART_ON_BOOT    — when 1, the systemd-user service for
#                                    this folder runs at login and
#                                    restarts on crash. Apply via:
#                                      ./scripts/manage-kernos-service.sh apply
#                                    Set to 0 (default) to keep this
#                                    folder out of the auto-restart loop —
#                                    typical for development clones where
#                                    you want manual ./start.sh control.
# KERNOS_START_KILL_PRIOR=1
# KERNOS_AUTO_RESTART_ON_BOOT=0

# === Auto-Update ===
# Kernos checks origin/{KERNOS_UPDATE_BRANCH} on startup and pulls + restarts
# if the remote is ahead. Falls back to current code on any failure mode.
# Also runs a daily background pull at KERNOS_AUTO_UPDATE_TIME (server local
# clock); the daily pull lands on disk and applies on the next natural restart
# without forcing a mid-flight restart.
#
#   KERNOS_AUTO_UPDATE         — master toggle. on (default) / off.
#   KERNOS_AUTO_UPDATE_TIME    — daily background pull window, HH:MM 24-hour
#                                local time. Default 03:00. Malformed values
#                                fall back to the default with a log warning.
#   KERNOS_AUTO_UPDATE_VERBOSE — operator-level opt-out for update
#                                notifications. on (default) = the substrate
#                                queues a post-update whisper carrying the
#                                substrate-event data; the agent reads its
#                                covenants and decides what to surface in
#                                its own voice. off = no whisper queued, the
#                                agent never knows the update happened.
#                                Granularity ("only tell me about tool
#                                updates", "stop after this") is governed
#                                by the agent's covenants in conversation,
#                                not by this env var.
#   KERNOS_UPDATE_BRANCH       — branch to track. Default main.
# KERNOS_AUTO_UPDATE=on
# KERNOS_AUTO_UPDATE_TIME=03:00
# KERNOS_AUTO_UPDATE_VERBOSE=on
# KERNOS_UPDATE_BRANCH=main    # override for dogfooding / pre-release branches

# === Workspace Scope ===
# Controls filesystem access for code the agent writes and runs.
#   isolated (default) — subprocess filesystem confined to the active space.
#                        Catches accidental spillover; not a security boundary.
#   unleashed          — subprocess shares the Kernos process's filesystem reach.
# KERNOS_WORKSPACE_SCOPE=isolated

# === Workspace Builder ===
# Which backend writes and runs workspace code.
#   native (default) — Kernos's sandboxed Python subprocess (this batch)
#   aider            — external Python tool (adapter batch pending)
#   claude-code      — external Node binary (adapter batch pending)
#   codex            — external Node binary (adapter batch pending)
# KERNOS_BUILDER=native

# Paths to external builder binaries (only consulted when the matching backend
# is selected; adapter implementations ship in follow-on batches).
# AIDER_BIN=/usr/local/bin/aider
# CLAUDE_CODE_BIN=/usr/local/bin/claude
# CODEX_BIN=/usr/local/bin/codex

# ─────────────────────────────────────────────
# DEBUG / TESTING
# ─────────────────────────────────────────────

# Override compaction threshold for testing (default: 8000 estimated tokens)
# Set low (e.g., 500) to trigger compaction after ~5-6 exchanges
# KERNOS_COMPACTION_THRESHOLD=500

# Event trigger poll interval in seconds (default: 60)
# KERNOS_EVENT_POLL_INTERVAL=60

# Max event trigger fires per day per standing trigger (default: 15)
# KERNOS_EVENT_DAILY_CAP=15

# AwarenessEvaluator main pass interval in seconds — how often the
# awareness loop runs its broader check (default: 1800 = 30 minutes)
# KERNOS_AWARENESS_INTERVAL=1800

# AwarenessEvaluator trigger-evaluation interval in seconds — how often
# the loop walks active triggers within each main pass (default: 15)
# KERNOS_TRIGGER_INTERVAL=15
