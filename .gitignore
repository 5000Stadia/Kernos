.venv/
__pycache__/
*.pyc
*.pyo
.env
.pytest_cache/
*.egg-info/
dist/
build/
credentials.json
data/
# Isolated data dirs from harnesses, dev clones, scratch runs. Never
# committed. Examples: data-soak/ (kernos/soak.py), data-dev/, data-tmp/.
data-*/
# Archived data dirs from clean-slate wipes (operational artifacts —
# preserved per-instance for recovery, never committed). Pattern matches
# both within-tree archives and accidentally-misplaced ones.
data.archived-*/
.claude/
secrets/
specs/completed/
.credentials/
Research/

# Per-install config generated by `kernos setup llm` / storage-backend setup.
# Local state — see config/llm_benchmark_snapshot.json (tracked, setup-time
# recommendation data) vs. these two files (per-install secrets wiring).
config/llm_chains.yml
config/storage_backend.yml

# Async file-drop channel between Claude Code and the owner-side
# Codex (see .codex_handoff/README.md). Operational artifacts —
# review requests + responses — never committed.
.codex_handoff/
